# Copy to .env and fill with your values

# API
# Ollama (local or remote host reachable from backend)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b-instruct
# Optional if your Ollama endpoint is behind auth proxy
OLLAMA_API_KEY=
# Per LLM HTTP call timeout (seconds). Set 0 to disable.
OLLAMA_REQUEST_TIMEOUT_SEC=90
# Max correction loops per /api/generate request
SOOG_LLM_MAX_ATTEMPTS=2
# Absolute request deadline for /api/generate (seconds). Set 0 to disable.
SOOG_GENERATE_DEADLINE_SEC=240
# Optional retry once without soopub context (0/1). Keep 0 on low-RAM hosts.
SOOG_RETRY_WITHOUT_CONTEXT=0
PORT=10000

# Hugging Face cache (optional)
HF_HOME=.cache/huggingface
