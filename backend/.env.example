# Copy to .env and fill with your values

# API
# Ollama (local or remote host reachable from backend)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=deepseek-r1:8b
# Optional if your Ollama endpoint is behind auth proxy
OLLAMA_API_KEY=
# Per LLM HTTP call timeout (seconds). Set 0 to disable.
OLLAMA_REQUEST_TIMEOUT_SEC=90
# LLM max output tokens per call (lower => faster responses)
SOOG_LLM_MAX_TOKENS=1000
# Ask Ollama native endpoints to expose thinking when the model supports it.
SOOG_OLLAMA_THINKING=1
# Keep progress snapshots available for frontend polling (seconds).
SOOG_PROGRESS_TTL_SEC=900
# Max correction loops per /api/generate request
SOOG_LLM_MAX_ATTEMPTS=2
# Absolute request deadline for /api/generate (seconds). Set 0 to disable.
SOOG_GENERATE_DEADLINE_SEC=240
# Max PNG bytes inlined in /api/generate JSON (0 disables inline image; use gallery URL only).
SOOG_MAX_INLINE_IMAGE_BYTES=600000
# Stable Diffusion organogram sketch output
SOOG_SKETCH_ENABLED=1
SOOG_SKETCH_MODEL=OFA-Sys/small-stable-diffusion-v0
SOOG_SKETCH_WIDTH=384
SOOG_SKETCH_HEIGHT=384
SOOG_SKETCH_STEPS=12
SOOG_SKETCH_STRENGTH=0.72
SOOG_SKETCH_GUIDANCE_SCALE=6.5
# Keep loaded between requests for faster iterations; disable on very low-RAM hosts.
SOOG_SKETCH_CACHE_PIPELINE=1
# Optional retry once without soopub context (0/1). Keep 0 on low-RAM hosts.
SOOG_RETRY_WITHOUT_CONTEXT=0
PORT=10000

# Hugging Face cache (optional)
HF_HOME=.cache/huggingface
